{
  "name": "dan-websocket",
  "version": "2.2.0",
  "description": "Lightweight binary protocol for real-time state synchronization",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.mjs",
      "require": "./dist/protocol.cjs"
    }
  },
  "files": [
    "dist",
    "dan-protocol.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "websocket",
    "binary",
    "protocol",
    "realtime",
    "synchronization"
  ],
  "author": "justdancecloud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/justdancecloud/danws_typescript.git"
  },
  "homepage": "https://github.com/justdancecloud/danws_typescript#readme",
  "bugs": {
    "url": "https://github.com/justdancecloud/danws_typescript/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
